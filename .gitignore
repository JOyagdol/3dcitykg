**/build/
!src/**/build/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignore Gradle wrappper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath

# Ignore Gradle build output directory
build

# CityGML Input data
input/citygml/SMARTCITY_LAB_(RV2024)_mod_room_noIfcFooting_window_metadata-manual-georeferenced-geomFixDynamic.gml

# CityGML Output data
output/